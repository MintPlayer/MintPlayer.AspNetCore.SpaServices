<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

	<!-- Import the FolderHasher task for SPA build caching -->
	<UsingTask TaskName="MintPlayer.FolderHasher.MSBuild.ComputeFolderHashTask"
	           AssemblyFile="$(MSBuildThisFileDirectory)MintPlayer.FolderHasher.MSBuild.dll" />

	<!-- Create default .hasherignore file if it doesn't exist -->
	<Target Name="EnsureHasherIgnoreFile"
	        Condition=" '$(EnableSpaBuilder)' == 'true' And '$(EnableSpaBuildCaching)' == 'true' And '$(CreateDefaultHasherIgnore)' == 'true' And Exists('$(SpaRoot)') And !Exists('$(SpaRoot).hasherignore') ">
		<Message Importance="normal" Text="Creating default .hasherignore file in $(SpaRoot)" />
		<ItemGroup>
			<_HasherIgnoreLines Include="# Default ignore patterns for SPA build caching" />
			<_HasherIgnoreLines Include="# Generated by MintPlayer.AspNetCore.NodeServices" />
			<_HasherIgnoreLines Include="# Customize this file to exclude additional files/folders from hash computation" />
			<_HasherIgnoreLines Include="@(SpaHashDefaultIgnorePattern)" />
		</ItemGroup>
		<WriteLinesToFile File="$(SpaRoot).hasherignore"
		                  Lines="@(_HasherIgnoreLines)"
		                  Overwrite="true" />
	</Target>

	<!-- Compute SPA folder hash and determine if rebuild is needed -->
	<Target Name="ComputeSpaFolderHash"
	        DependsOnTargets="EnsureHasherIgnoreFile"
	        Condition=" '$(EnableSpaBuilder)' == 'true' And '$(EnableSpaBuildCaching)' == 'true' And Exists('$(SpaRoot)') ">

		<!-- Read previous hash if it exists -->
		<PropertyGroup>
			<PreviousSpaHash Condition="Exists('$(SpaHashFilePath)')">$([System.IO.File]::ReadAllText('$(SpaHashFilePath)').Trim())</PreviousSpaHash>
			<PreviousSpaHash Condition="!Exists('$(SpaHashFilePath)')"></PreviousSpaHash>
		</PropertyGroup>

		<!-- Compute current hash -->
		<ComputeFolderHashTask FolderPath="$(SpaRoot)">
			<Output TaskParameter="Hash" PropertyName="CurrentSpaHash" />
		</ComputeFolderHashTask>

		<!-- Determine if source changed -->
		<PropertyGroup>
			<!-- Force rebuild if explicitly requested -->
			<SpaSourceChanged Condition=" '$(ForceSpaBuild)' == 'true' ">true</SpaSourceChanged>
			<!-- First build (no previous hash) -->
			<SpaSourceChanged Condition=" '$(ForceSpaBuild)' != 'true' And '$(PreviousSpaHash)' == '' ">true</SpaSourceChanged>
			<!-- Hash changed -->
			<SpaSourceChanged Condition=" '$(ForceSpaBuild)' != 'true' And '$(PreviousSpaHash)' != '' And '$(PreviousSpaHash)' != '$(CurrentSpaHash)' ">true</SpaSourceChanged>
			<!-- Hash unchanged -->
			<SpaSourceChanged Condition=" '$(ForceSpaBuild)' != 'true' And '$(PreviousSpaHash)' != '' And '$(PreviousSpaHash)' == '$(CurrentSpaHash)' ">false</SpaSourceChanged>
		</PropertyGroup>

		<Message Importance="high"
		         Text="SPA source unchanged (hash: $(CurrentSpaHash)). Skipping npm build."
		         Condition=" '$(SpaSourceChanged)' == 'false' " />
		<Message Importance="high"
		         Text="SPA source changed. Will rebuild. (Previous: $(PreviousSpaHash), Current: $(CurrentSpaHash))"
		         Condition=" '$(SpaSourceChanged)' == 'true' And '$(PreviousSpaHash)' != '' " />
		<Message Importance="high"
		         Text="First SPA build detected (hash: $(CurrentSpaHash)). Will build."
		         Condition=" '$(SpaSourceChanged)' == 'true' And '$(PreviousSpaHash)' == '' " />
	</Target>

	<!-- Debug: Ensure Node environment and install dependencies -->
	<Target Name="DebugEnsureNodeEnv"
	        BeforeTargets="Build"
	        DependsOnTargets="ComputeSpaFolderHash"
	        Condition=" '$(EnableSpaBuilder)' == 'true' And '$(Configuration)' == 'Debug' And !Exists('$(NodeModulesCheckPath)node_modules') ">
		<!-- Ensure Node.js is installed -->
		<Exec Command="node --version" ContinueOnError="true">
			<Output TaskParameter="ExitCode" PropertyName="ErrorCode" />
		</Exec>
		<Error Condition="'$(ErrorCode)' != '0'" Text="Node.js is required to build and run this project. To continue, please install Node.js from https://nodejs.org/, and then restart your command prompt or IDE." />

		<!-- Delegate to npm-install.proj. MSBuild deduplicates: when multiple projects
		     in a parallel solution build call this with the same properties, it runs only once. -->
		<MSBuild Projects="$(MSBuildThisFileDirectory)npm-install.proj"
		         Targets="NpmInstall"
		         Properties="NpmInstallWorkingDirectory=$(NpmInstallWorkingDirectory);NodeModulesCheckPath=$(NodeModulesCheckPath)" />
	</Target>

	<!-- Publish: Build the SPA (with caching support) -->
	<Target Name="PublishRunWebpack"
	        AfterTargets="ComputeFilesToPublish"
	        DependsOnTargets="ComputeSpaFolderHash"
	        Condition=" '$(EnableSpaBuilder)' == 'true' ">

		<!-- Warn if SpaRoot doesn't exist -->
		<Warning Text="SPA root folder '$(SpaRoot)' does not exist. SPA build will be skipped."
		         Condition=" !Exists('$(SpaRoot)') " />

		<!-- Determine if we need to run npm build (default: true for fail-safe behavior) -->
		<PropertyGroup>
			<_RunNpmBuild>true</_RunNpmBuild>
			<!-- Skip build only when: caching enabled AND source unchanged AND dist exists AND SpaRoot exists -->
			<_RunNpmBuild Condition=" '$(EnableSpaBuildCaching)' == 'true' And '$(SpaSourceChanged)' == 'false' And Exists('$(SpaRoot)dist') ">false</_RunNpmBuild>
			<!-- Never run build if SpaRoot doesn't exist -->
			<_RunNpmBuild Condition=" !Exists('$(SpaRoot)') ">false</_RunNpmBuild>
		</PropertyGroup>

		<Message Importance="high" Text="Using cached SPA build output from $(SpaRoot)dist" Condition=" '$(_RunNpmBuild)' != 'true' And Exists('$(SpaRoot)') " />

		<!-- As part of publishing, ensure the JS resources are freshly built in production mode -->
		<MSBuild Projects="$(MSBuildThisFileDirectory)npm-install.proj"
		         Targets="NpmInstall"
		         Properties="NpmInstallWorkingDirectory=$(NpmInstallWorkingDirectory);NodeModulesCheckPath=$(NodeModulesCheckPath)"
		         Condition=" '$(_RunNpmBuild)' == 'true' " />

		<!-- Build command selection based on BuildServerSideRenderer:
		     If true:  npm run build:ssr:production
		     If false: npm run build (with production configuration) -->
		<Exec WorkingDirectory="$(SpaRoot)" Command="npm run build -- --configuration production" Condition=" '$(_RunNpmBuild)' == 'true' And '$(BuildServerSideRenderer)' != 'true' " />
		<Exec WorkingDirectory="$(SpaRoot)" Command="npm run build:ssr:production" Condition=" '$(_RunNpmBuild)' == 'true' And '$(BuildServerSideRenderer)' == 'true' " />

		<!-- Save hash after successful build (only if hash is not empty) -->
		<MakeDir Directories="$([System.IO.Path]::GetDirectoryName('$(SpaHashFilePath)'))" Condition=" '$(EnableSpaBuildCaching)' == 'true' And '$(_RunNpmBuild)' == 'true' And '$(CurrentSpaHash)' != '' " />
		<WriteLinesToFile File="$(SpaHashFilePath)"
		                  Lines="$(CurrentSpaHash)"
		                  Overwrite="true"
		                  Condition=" '$(EnableSpaBuildCaching)' == 'true' And '$(_RunNpmBuild)' == 'true' And '$(CurrentSpaHash)' != '' " />
		<Message Importance="normal" Text="Saved SPA hash to $(SpaHashFilePath)" Condition=" '$(EnableSpaBuildCaching)' == 'true' And '$(_RunNpmBuild)' == 'true' And '$(CurrentSpaHash)' != '' " />

		<!-- Always include the built files in the publish output -->
		<ItemGroup>
			<DistFiles Include="$(SpaRoot)dist\**; $(SpaRoot)dist-server\**" />
			<DistFiles Include="$(SpaRoot)node_modules\**" Condition="'$(BuildServerSideRenderer)' == 'true'" />
			<ResolvedFileToPublish Include="@(DistFiles->'%(FullPath)')" Exclude="@(ResolvedFileToPublish)">
				<RelativePath>%(DistFiles.Identity)</RelativePath>
				<CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
				<ExcludeFromSingleFile>true</ExcludeFromSingleFile>
			</ResolvedFileToPublish>
		</ItemGroup>
	</Target>

</Project>
